# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPOS=repo1,repo2        # comma-separated repo names within the org

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=           # used by Cloudflare Worker to verify button callbacks

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# AI — pick one provider and set the matching API key
AI_MODEL=gpt-4o-mini            # or: claude-sonnet-4-6, gemini/gemini-1.5-flash, groq/llama3-70b-8192, ollama/llama3
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
